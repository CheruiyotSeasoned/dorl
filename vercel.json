{
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Service-Worker-Allowed", "value": "/" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/((?!sw\\.js|workbox-|manifest\\.webmanifest|icons/).*)",
      "destination": "/index.html"
    }
  ]
}
